{
  "name": "network3d",
  "private": true,
  "version": "0.0.0",
  "type": "module",

  "main": "./dist/network3d.cjs",
  "module": "./dist/network3d.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/network3d.js",
      "require": "./dist/network3d.cjs"
    }
  },

  "scripts": {
    "dev": "vite",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "vite build && npm run build:types",
    "preview": "vite preview",
    "test": "vitest"
  },
  "devDependencies": {
    "typescript": "~5.8.3",
    "vite": "^7.1.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "ohm-js": "^17.3.0"
  }
}
